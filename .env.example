# Copie para .streamlit/secrets.toml (formato TOML) para rodar local.
# No deploy do Streamlit Cloud, cole esses valores em "Settings -> Secrets".

# Supabase: projeto -> Settings -> API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Voyage AI: https://www.voyageai.com/ -> API Keys
VOYAGE_API_KEY=pa-...

# Groq: https://console.groq.com/ -> API Keys
GROQ_API_KEY=gsk_...

# Limites
MAX_FILE_SIZE_MB=50

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# RAG
TOP_K_CHUNKS=6
